# Supabase configuration for @supabase/server
# Copy this file to `.env` and paste the REAL values from your Supabase dashboard:
#   Project → Connect (or Project Settings → API).
# NEVER commit `.env` or the secret key. `.env` is git-ignored.
#
# On Supabase Edge Functions these four variables are injected automatically at
# runtime, so you do NOT need to set them in the dashboard for deployed functions.
# They are only needed for LOCAL development (`supabase functions serve`) and for
# running @supabase/server outside of Supabase's managed runtime.

# Your project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=

# Publishable (anon) key — safe to expose to clients. Gates "publishable" auth mode.
SUPABASE_PUBLISHABLE_KEY=

# Secret (service-role) key — SERVER ONLY. Bypasses Row Level Security via
# ctx.supabaseAdmin. NEVER ship this to the browser / index.html / any client.
SUPABASE_SECRET_KEY=

# JWKS endpoint used to verify end-user JWTs (auth mode "user").
# Usually: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
